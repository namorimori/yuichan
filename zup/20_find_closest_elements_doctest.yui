>>> find_closest_elements([1.000000, 2.000000, 3.900000, 4.000000, 5.000000, 2.200000]) 
[3.900000, 4.000000]
>>> find_closest_elements([1.000000, 2.000000, 5.900000, 4.000000, 5.000000]) 
[5.000000, 5.900000]
>>> find_closest_elements([1.000000, 2.000000, 3.000000, 4.000000, 5.000000, 2.200000]) 
[2.000000, 2.200000]
>>> find_closest_elements([1.000000, 2.000000, 3.000000, 4.000000, 5.000000, 2.000000]) 
[2.000000, 2.000000]
>>> find_closest_elements([1.100000, 2.200000, 3.100000, 4.100000, 5.100000]) 
[2.200000, 3.100000]