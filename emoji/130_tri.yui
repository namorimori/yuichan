   48.000000,
   7.000000,
   63.000000,
   8.000000,
   80.000000,
   9.000000,
   99.000000,
   10.000000,
   120.000000,
   11.000000
]
>>> tri(0) 
[1]
>>> tri(1) 
[1, 3]