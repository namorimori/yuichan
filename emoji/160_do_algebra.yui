            🔚
         🔚
      🔚
   🔚
   ✅ vals[0]
🔚
>>> do_algebra([], [1]) 
1
>>> do_algebra(["**", "*", "+"], [2, 3, 4, 5]) 
37
>>> do_algebra(["+", "*", "-"], [2, 3, 4, 5]) 
9
>>> do_algebra(["//", "*"], [7, 3, 4]) 
8