Use the standard library
use std

func has_close_elements(numbers, threshold) {
    let n = len(numbers)
    let i = 0

    while i < n {
        let j = i + 1
        while j < n {
            if abs(numbers[i] - numbers[j]) < threshold {
                return 1
            }
            j = j + 1
        }
        i = i + 1
    }

    return 0
}