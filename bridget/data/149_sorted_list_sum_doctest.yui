>>> sorted_list_sum of ["aa", "a", "aaa"] 
["aa"]
>>> sorted_list_sum of ["school", "AI", "asdf", "b"] 
["AI", "asdf", "school"]
>>> sorted_list_sum of ["d", "b", "c", "a"] 
[]
>>> sorted_list_sum of ["d", "dcba", "abcd", "a"] 
["abcd", "dcba"]
>>> sorted_list_sum of ["AI", "ai", "au"] 
["AI", "ai", "au"]
>>> sorted_list_sum of ["a", "b", "b", "c", "c", "a"] 
[]
>>> sorted_list_sum of ["aaaa", "bbbb", "dd", "cc"] 
["cc", "dd", "aaaa", "bbbb"]