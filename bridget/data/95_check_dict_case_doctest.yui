>>> check_dict_case of {"p": "pineapple", "b": "banana"} 
1
>>> check_dict_case of {"p": "pineapple", "A": "banana", "B": "banana"} 
0
>>> check_dict_case of {"Name": "John", "Age": "36", "City": "Houston"} 
0
>>> check_dict_case of {"STATE": "NC", "ZIP": "12345"} 
1
>>> check_dict_case of {"fruit": "Orange", "taste": "Sweet"} 
1
>>> check_dict_case of {} 
0