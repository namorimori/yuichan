>>> sort_array of [] 
[]
>>> sort_array of [5] 
[5]
>>> sort_array of [2, 4, 3, 0, 1, 5] 
[0, 1, 2, 3, 4, 5]
>>> sort_array of [2, 4, 3, 0, 1, 5, 6] 
[6, 5, 4, 3, 2, 1, 0]
>>> sort_array of [2, 1] 
[1, 2]
>>> sort_array of [15, 42, 87, 32, 11, 0] 
[0, 11, 15, 32, 42, 87]
>>> sort_array of [21, 14, 23, 11] 
[23, 21, 14, 11]