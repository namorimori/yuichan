標準ライブラリを使う
# 「のいずれか」「のいずれでもない」による集合検索

menu=["カレー","ラーメン","寿司","そば"]

# のいずれか: 要素が含まれるかを調べる
check=入力itemに対し{
   もしitemがmenuのいずれかならば{
      "あります"が答え
   }
   そうでなければ{
      "ありません"が答え
   }
}

>>> check("寿司")
"あります"
>>> check("ピザ")
"ありません"

# のいずれでもない: 含まれないかを直接調べる (アレルギー判定)
allergy=["卵","そば","小麦"]

safe=入力foodに対し{
   もしfoodがallergyのいずれでもないならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}

>>> safe("カレー")
真
>>> safe("そば")
偽
>>> safe("卵")
偽
