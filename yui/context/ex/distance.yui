標準ライブラリを使う
# 2 点間のユークリッド距離 d = √((x2-x1)^2 + (y2-y1)^2)
distance=入力x1,y1,x2,y2に対し{
   dx=差(x2,x1)
   dy=差(y2,y1)
   d2=和(積(dx,dx),積(dy,dy))
   平方根(d2)が答え
}

# テスト: 3-4-5 の直角三角形
>>> distance(0,0,3,4)
5.000000
# テスト: 同じ点の距離は 0
>>> distance(7,7,7,7)
0.000000
# テスト: 負の座標を含む  (-1,0)→(2,4) も差は (3,4)
>>> distance(-1,0,2,4)
5.000000
# テスト: 5-12-13
>>> distance(0,0,5,12)
13.000000
