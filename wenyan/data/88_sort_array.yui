[5]
>>> 施排序於[2,4,3,0,1,5]
[0,1,2,3,4,5]
>>> 施排序於[2,4,3,0,1,5,6]
[6,5,4,3,2,1,0]
>>> 施排序於[2,1]
[1,2]
