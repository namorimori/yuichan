[「AI」,「ai」,「au」]
>>> 施序分於[「a」,「b」,「b」,「c」,「c」,「a」]
[]
>>> 施序分於[「aaaa」,「bbbb」,「dd」,「cc」]
[「cc」,「dd」,「aaaa」,「bbbb」]
